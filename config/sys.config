[
    {kernel, [
        {logger_level, notice},
        %% Fix distribution port to 9101 (predictable for firewall rules)
        {inet_dist_listen_min, 9101},
        {inet_dist_listen_max, 9101},
        %% Bind distribution to localhost only (hardening)
        %% install.sh patches this to private IP for cluster mode
        {inet_dist_use_interface, {127,0,0,1}}
    ]}
].
