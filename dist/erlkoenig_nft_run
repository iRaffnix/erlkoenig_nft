#!/bin/sh
# Start erlkoenig_nft as a standalone daemon (no Erlang distribution).
# Managed by systemd — shutdown via SIGTERM.

ROOTDIR="${ERLKOENIG_ROOTDIR:-$(cd "$(dirname "$0")/.." && pwd)}"
REL_VSN=$(cut -d' ' -f2 < "$ROOTDIR/releases/start_erl.data")
ERTS_VSN=$(cut -d' ' -f1 < "$ROOTDIR/releases/start_erl.data")

exec "$ROOTDIR/erts-$ERTS_VSN/bin/erl" \
    -boot "$ROOTDIR/releases/$REL_VSN/start" \
    -mode embedded \
    -boot_var SYSTEM_LIB_DIR "$ROOTDIR/lib" \
    -config "$ROOTDIR/releases/$REL_VSN/sys.config" \
    -args_file "$ROOTDIR/releases/$REL_VSN/vm.args" \
    -noinput
