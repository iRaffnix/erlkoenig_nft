#!/bin/bash
# erlkoenig CLI — nf_tables firewall DSL compiler
#
# Build:  cd dsl && mix escript.build
# Usage:  ./erlkoenig show examples/hardened_webserver.exs

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ESCRIPT="$SCRIPT_DIR/dsl/erlkoenig"

if [ ! -f "$ESCRIPT" ]; then
    echo "Building erlkoenig CLI..."
    (cd "$SCRIPT_DIR/dsl" && mix escript.build) || exit 1
fi

exec "$ESCRIPT" "$@"
