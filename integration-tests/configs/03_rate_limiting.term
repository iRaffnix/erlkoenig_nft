#{counters => [<<"ssh_counted">>,<<"api">>,<<"dropped">>],
  table => <<"test_ratelimit">>,
  chains =>
      [#{name => <<"inbound">>,priority => 0,type => filter,hook => input,
         policy => drop,
         rules =>
             [ct_established_accept,
              {iifname_accept,<<"lo">>},
              {tcp_accept,22},
              {tcp_accept_limited,2222,<<"ssh_counted">>,
                                  #{burst => 3,rate => 10}},
              {tcp_accept,80,<<"api">>},
              icmp_accept,
              {log_drop,<<"RATE-DROP: ">>,<<"dropped">>}]}]}.
