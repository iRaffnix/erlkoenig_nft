#{counters =>
      [<<"ssh_counted">>,<<"http">>,<<"https">>,<<"dns">>,<<"dropped">>],
  table => <<"test_counters">>,
  chains =>
      [#{name => <<"inbound">>,priority => 0,type => filter,hook => input,
         policy => drop,
         rules =>
             [ct_established_accept,
              {iifname_accept,<<"lo">>},
              {tcp_accept,22},
              {tcp_accept,2222,<<"ssh_counted">>},
              {tcp_accept,80,<<"http">>},
              {tcp_accept,443,<<"https">>},
              {udp_accept,53,<<"dns">>},
              icmp_accept,
              {log_drop,<<"DROP: ">>,<<"dropped">>}]}]}.
