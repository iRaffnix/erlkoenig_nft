#{counters => [<<"ssh_counted">>,<<"dns">>,<<"dropped">>],
  table => <<"test_conntrack">>,
  chains =>
      [#{name => <<"raw_prerouting">>,priority => -300,type => filter,
         hook => prerouting,policy => accept,
         rules => [{notrack,53,udp},{notrack,123,udp}]},
       #{name => <<"inbound">>,priority => 0,type => filter,hook => input,
         policy => drop,
         rules =>
             [ct_established_accept,
              {iifname_accept,<<"lo">>},
              {tcp_accept,22},
              {tcp_accept,2222,<<"ssh_counted">>},
              {udp_accept,53,<<"dns">>},
              {udp_accept,123},
              icmp_accept,
              {log_drop,<<"CT-DROP: ">>,<<"dropped">>}]}]}.
