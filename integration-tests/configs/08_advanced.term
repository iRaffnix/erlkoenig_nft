#{counters => [<<"ssh_counted">>,<<"http">>,<<"https">>,<<"dropped">>],
  table => <<"test_advanced">>,
  chains =>
      [#{name => <<"prerouting_filter">>,priority => -200,type => filter,
         hook => prerouting,policy => accept,
         rules => [fib_rpf_drop]},
       #{name => <<"inbound">>,priority => 0,type => filter,hook => input,
         policy => drop,
         rules =>
             [ct_established_accept,
              {iifname_accept,<<"lo">>},
              {tcp_accept,22},
              {tcp_accept,2222,<<"ssh_counted">>},
              {vmap_dispatch,tcp,<<"port_vmap">>},
              icmp_accept,
              {log_drop_nflog,<<"ADV-DROP: ">>,1,<<"dropped">>}]}],
  vmaps =>
      [#{name => <<"port_vmap">>,type => inet_service,
         entries => [{80,accept},{443,accept},{53,accept}]}]}.
