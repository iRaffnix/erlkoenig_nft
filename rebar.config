{erl_opts, [debug_info, warnings_as_errors]}.
{minimum_otp_vsn, "28"}.
{deps, []}.

{dialyzer, [
    {warnings, [
        error_handling,
        underspecs,
        unmatched_returns
    ]},
    {plt_extra_apps, [crypto]}
]}.

{project_plugins, [erlfmt, rebar3_hex, rebar3_ex_doc]}.

{erlfmt, [write]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/iRaffnix/erlkoenig_nft">>},
    {extras, [<<"README.md">>]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls
]}.

{relx, [
    {release, {erlkoenig_nft, "0.7.0"}, [sasl, compiler, erlkoenig_nft]},
    {mode, minimal},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args_src, "config/vm.args.src"},
    {overlay, [
        {copy, "dist/erlkoenig_nft.service", "dist/erlkoenig_nft.service"},
        {copy, "examples", "examples"},
        {copy, "dsl/erlkoenig", "bin/erlkoenig"}
    ]}
]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, [
            {assert, {git, "https://github.com/WhatsApp/assert.git", {branch, "main"}}},
            {proper, "1.4.0"}
        ]}
    ]},
    {prod, [
        {relx, [
            {mode, prod},
            {include_erts, true},
            {include_src, false},
            {debug_info, strip}
        ]}
    ]}
]}.
