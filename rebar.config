{erl_opts, [debug_info]}.
{deps, []}.

{dialyzer, [
    {warnings, [unmatched_returns, error_handling]},
    {plt_extra_apps, [crypto]}
]}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/erlkoenig-io/erlkoenig">>},
    {extras, [<<"README.md">>]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

{relx, [
    {release, {erlkoenig_nft, "0.4.0"}, [sasl, erlkoenig_nft]},
    {mode, minimal},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]}
    ]},
    {prod, [
        {relx, [
            {mode, prod},
            {include_erts, true}
        ]}
    ]}
]}.
