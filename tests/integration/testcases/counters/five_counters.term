#{counters => [<<"ssh">>,<<"http">>,<<"https">>,<<"dns">>,<<"dropped">>],
  table => <<"test">>,
  chains =>
      [#{name => <<"input">>,priority => 0,type => filter,hook => input,
         policy => drop,
         rules =>
             [ct_established_accept,
              {tcp_accept,22,<<"ssh">>},
              {tcp_accept,80,<<"http">>},
              {tcp_accept,443,<<"https">>},
              {udp_accept,53,<<"dns">>},
              {log_drop,<<"DROP: ">>,<<"dropped">>}]}]}.
